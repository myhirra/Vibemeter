# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local data (never commit)
.data/

# menubar build artifact
tools/menubar/Vibemeter.app/

# marketing/ 是私有推广素材：发文案、视频脚本、发布 playbook。
# 不进主仓库（绝不上 GitHub），有独立的 git 仓库推到 hirra.cn。
# 详见 CLAUDE.md / AGENTS.md。
/marketing/

# docs/superpowers/ 是私有 skills，独立 git，不进主仓库
/docs/superpowers/
